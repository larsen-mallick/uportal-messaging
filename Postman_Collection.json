    {
      "name": "User Messages",
      "item": [
        {
          "name": "Get Messages for User (No Groups)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/messages",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "messages"
              ]
            },
            "description": "Retrieve messages accessible to a user without any group memberships. Returns only messages with no group restrictions and valid dates."
          },
          "response": []
        },
        {
          "name": "Get Messages for User (Portal Administrators Group)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "isMemberOf",
                "value": "Portal Administrators",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/messages",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "messages"
              ]
            },
            "description": "Retrieve messages for a user who is a member of the 'Portal Administrators' group. Returns filtered messages based on group membership, date restrictions, and expiration."
          },
          "response": []
        },
        {
          "name": "Get Messages for User (Multiple Groups)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "isMemberOf",
                "value": "Portal Administrators;Students;Faculty",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/messages",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "messages"
              ]
            },
            "description": "Retrieve messages for a user who is a member of multiple groups (semicolon-delimited). Returns messages accessible to any of these group memberships."
          },
          "response": []
        },
        {
          "name": "Get Specific Message by ID (User Access)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "isMemberOf",
                "value": "Portal Administrators",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/messages/demo-high-priority-valid-group-valid-date",
