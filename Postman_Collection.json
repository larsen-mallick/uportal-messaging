              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "messages",
                "demo-high-priority-valid-group-valid-date"
              ]
            },
            "description": "Retrieve a specific message by ID for a user. Returns the message only if user has access based on group membership and date restrictions."
          },
          "response": []
        }
